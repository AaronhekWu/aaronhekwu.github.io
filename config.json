{
  "api": {
    "provider": "gemini",
    "temperature": 0.7,
    "maxTokens": 8000
  },
  "providers": {
    "gemini": {
      "name": "Gemini 3 Flash",
      "model": "gemini-3-flash-preview",
      "envKey": "GEMINI_API_KEY"
    },
    "gpt5mini": {
      "name": "GPT-5 mini",
      "model": "openai/gpt-5-mini-2025-08-07",
      "envKey": "OPENAI_API_KEY"
    },
    "deepseek": {
      "name": "DeepSeek",
      "model": "deepseek-chat",
      "envKey": "DEEPSEEK_API_KEY"
    },
    "qwen": {
      "name": "通义千问",
      "model": "qwen-plus",
      "envKey": "QWEN_API_KEY"
    }
  },
  "promptTemplate": "nvc-prompt-template.md"
}
